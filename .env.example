# Copy to .env and fill in. The crew reads these at startup (python-dotenv).
# `crewai deploy create` also transfers these to CrewAI AMP as deployment env vars.

# --- LLM provider (pick ONE and set its key) ---
# The model id follows LiteLLM naming used by CrewAI.
ANALYST_DESK_MODEL=gpt-4o-mini

# OpenAI (default provider for gpt-* models)
OPENAI_API_KEY=

# Anthropic (use ANALYST_DESK_MODEL=anthropic/claude-3-5-sonnet-latest)
# ANTHROPIC_API_KEY=

# Azure OpenAI (use ANALYST_DESK_MODEL=azure/<deployment-name>)
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=

# --- Corporate SSL (only if yfinance hits a self-signed cert chain) ---
# Point these at an exported CA bundle so the fetch scripts can reach Yahoo.
# REQUESTS_CA_BUNDLE=C:\Users\<you>\corp-ca-bundle.pem
# SSL_CERT_FILE=C:\Users\<you>\corp-ca-bundle.pem
# CURL_CA_BUNDLE=C:\Users\<you>\corp-ca-bundle.pem

# --- CrewAI telemetry (optional; silences telemetry SSL noise behind a proxy) ---
# CREWAI_DISABLE_TELEMETRY=true
# OTEL_SDK_DISABLED=true
